{
  "manifest_version": 3,
  "name": "BOSS直聘招聘辅助",
  "version": "1.3.1",
  "minimum_chrome_version": "120",
  "description": "BOSS直聘智能招聘辅助工具",
  "permissions": [
    "tabs",
    "activeTab",
    "windows",
    "cookies",
    "scripting",
    "alarms",
    "storage",
    "webNavigation",
    "webRequest",
    "downloads",
    "sidePanel"
  ],
  "side_panel": {
    "default_path": "src/ui/monitor/index.html"
  },
  "host_permissions": [
    "https://*.zhipin.com/*",
    "https://zhipin.com/*"
  ],
  "optional_host_permissions": [
    "https://*/*"
  ],
  "background": {
    "service_worker": "src/background/index.js"
  },
  "icons": {
    "16": "src/assets/icons/icon16.png",
    "32": "src/assets/icons/icon32.png",
    "48": "src/assets/icons/icon48.png",
    "128": "src/assets/icons/icon128.png"
  },
  "action": {
    "default_title": "BOSS直聘招聘辅助",
    "default_icon": {
      "16": "src/assets/icons/icon16.png",
      "32": "src/assets/icons/icon32.png",
      "48": "src/assets/icons/icon48.png",
      "128": "src/assets/icons/icon128.png"
    }
  },
  "options_page": "src/ui/options/index.html",
  "content_scripts": [
    {
      "matches": ["https://*.zhipin.com/*", "https://zhipin.com/*"],
      "js": ["src/content/main-world.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": ["https://*.zhipin.com/*", "https://zhipin.com/*"],
      "js": ["src/content/content.js"],
      "run_at": "document_start",
      "world": "ISOLATED",
      "all_frames": true
    }
  ]
}
